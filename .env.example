# Copy to .env (alongside docker-compose.yml) and adjust for your deployment.
# These values are baked into the static frontends at container start, NOT at build.
# Changing them only requires `docker compose restart editor apprenant`.

# Public URLs — what the BROWSER will use to reach each service.
# Behind Cloudflare Tunnel, these are the hostnames you've mapped in your tunnel config.
POCKETBASE_PUBLIC_URL=https://pb.example.com
EDITOR_PUBLIC_URL=https://admin-ar.example.com
APPRENANT_PUBLIC_URL=https://ar.example.com

# Host ports (what cloudflared targets on this machine).
# Leave defaults if no conflict — change if another service uses them.
POCKETBASE_PORT=8090
EDITOR_PORT=8081
APPRENANT_PORT=8082
